# Agent Server API URL
# This is the URL of the agent-server backend that provides
# projects, goals, tickets, harness detection, and agent execution.
VITE_AGENT_SERVER_URL=http://localhost:3090

# Runtime API URLs advertised to planner/orchestrator agent runs.
# Agents probe these in order with GET /live and use the first healthy URL.
GOBLINS_AGENT_API_BASE_URLS=http://127.0.0.1:3090,http://host.docker.internal:3090,http://192.168.29.142:3090

# API runtime setting for Codex-backed planner/orchestrator runs.
GOBLINS_CODEX_SANDBOX_MODE=danger-full-access
GOBLINS_CODEX_NETWORK_ACCESS=true
